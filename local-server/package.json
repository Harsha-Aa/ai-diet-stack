{
  "name": "local-server",
  "version": "1.0.0",
  "description": "Local development server for Lambda functions",
  "main": "server.ts",
  "scripts": {
    "start": "node server.js",
    "start:ts": "ts-node server.ts",
    "dev": "nodemon --watch server.js server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:start:staging": "pm2 start ecosystem.config.js --env staging",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs ai-diet-api",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "docker:build": "docker build -t ai-diet-api .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f api",
    "docker:restart": "docker-compose restart api"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/aws-lambda": "^8.10.161",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "pm2": "^5.3.0"
  }
}
