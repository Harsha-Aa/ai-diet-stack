{
  "name": "local-server",
  "version": "1.0.0",
  "description": "Local development server for Lambda functions",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "start": "node server.js",
    "postinstall": "npm run build",
    "start:ts": "ts-node server.ts",
    "dev": "nodemon --watch server.js server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:start:staging": "pm2 start ecosystem.config.js --env staging",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs ai-diet-api",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "docker:build": "docker build -t ai-diet-api .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f api",
    "docker:restart": "docker-compose restart api"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.621.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.621.0",
    "@aws-sdk/client-dynamodb": "^3.621.0",
    "@aws-sdk/client-rekognition": "^3.621.0",
    "@aws-sdk/client-s3": "^3.621.0",
    "@aws-sdk/client-transcribe": "^3.621.0",
    "@aws-sdk/lib-dynamodb": "^3.621.0",
    "@aws-sdk/s3-request-presigner": "^3.621.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "aws-jwt-verify": "^4.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "nodemon": "^3.0.2",
    "pm2": "^5.3.0",
    "ts-node": "^10.9.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
  }
}
