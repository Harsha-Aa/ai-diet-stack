# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# CDK Configuration
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1

# Stage (dev, staging, prod)
STAGE=dev

# ============================================================
# SECRETS MANAGEMENT
# ============================================================
# NOTE: Actual secrets are stored in AWS Secrets Manager and Parameter Store
# These are reference values for local development only
# See SECRETS_MANAGEMENT.md for full documentation

# Secrets Manager Secrets (DO NOT commit actual values)
# These are managed by CDK and retrieved at runtime
# Path format: /{environment}/ai-diet/{secret-name}

# Database credentials (for future RDS use)
# Retrieved via: getDatabaseCredentials()
# DB_USERNAME=admin
# DB_PASSWORD=<auto-generated>
# DB_HOST=<rds-endpoint>
# DB_PORT=5432
# DB_NAME=aidiet

# JWT signing secret
# Retrieved via: getJwtSecret()
# JWT_SECRET=<auto-generated-64-char-secret>

# Application encryption key
# Retrieved via: getEncryptionKey()
# ENCRYPTION_KEY=<auto-generated-64-char-key>

# Stripe API key (update manually after deployment)
# Retrieved via: getStripeApiKey()
# STRIPE_API_KEY=sk_test_... (dev/staging) or sk_live_... (prod)

# Dexcom CGM API credentials (update manually after deployment)
# Retrieved via: getDexcomApiCredentials()
# DEXCOM_CLIENT_ID=<your-client-id>
# DEXCOM_CLIENT_SECRET=<your-client-secret>
# DEXCOM_REDIRECT_URI=https://api.aidiet.app/cgm/dexcom/callback

# Libre CGM API credentials (update manually after deployment)
# Retrieved via: getLibreApiCredentials()
# LIBRE_CLIENT_ID=<your-client-id>
# LIBRE_CLIENT_SECRET=<your-client-secret>
# LIBRE_REDIRECT_URI=https://api.aidiet.app/cgm/libre/callback

# ============================================================
# PARAMETER STORE PARAMETERS
# ============================================================
# These are non-sensitive configuration values
# Path format: /{environment}/ai-diet/{parameter-name}

# Bedrock Configuration
# Retrieved via: getBedrockModelId(), getBedrockRegion()
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1

# Notification Configuration
# Retrieved via: getSesFromEmail()
SES_FROM_EMAIL=noreply@aidiet.app

# API Configuration
# Retrieved via: getApiRateLimit(), getSessionTimeoutMinutes()
API_RATE_LIMIT=100
SESSION_TIMEOUT_MINUTES=60

# Free Tier Limits (JSON)
# Retrieved via: getFreeTierLimits()
# FREE_TIER_LIMITS={"food_recognition":25,"glucose_prediction":20,"meal_recommendation":15,"voice_entry":20,"text_nutrient_analysis":25,"insulin_dose":20,"pattern_insight":1}

# ============================================================
# CDK-GENERATED RESOURCE IDENTIFIERS
# ============================================================
# These are auto-generated by CDK and exported as stack outputs
# Use these for reference only - actual values come from CloudFormation

# DynamoDB Table Names (auto-generated by CDK, for reference)
USER_PROFILES_TABLE=ai-diet-user-profiles
GLUCOSE_READINGS_TABLE=ai-diet-glucose-readings
FOOD_LOGS_TABLE=ai-diet-food-logs
USAGE_TRACKING_TABLE=ai-diet-usage-tracking
ACTIVITY_LOGS_TABLE=ai-diet-activity-logs

# S3 Bucket Names (auto-generated by CDK, for reference)
FOOD_IMAGES_BUCKET=ai-diet-food-images-bucket
REPORTS_BUCKET=ai-diet-reports-bucket

# Cognito Configuration (auto-generated by CDK, for reference)
USER_POOL_ID=us-east-1_XXXXXXXXX
USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# API Gateway Configuration (auto-generated by CDK, for reference)
API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# SNS Topic ARN (auto-generated by CDK, for reference)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ai-diet-notifications

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_CGM_SYNC=true
ENABLE_VOICE_ENTRY=true
ENABLE_PROVIDER_ACCESS=true

# ============================================================
# MONITORING & LOGGING
# ============================================================
LOG_LEVEL=INFO
ENABLE_XRAY_TRACING=true

# ============================================================
# COST OPTIMIZATION
# ============================================================
S3_LIFECYCLE_DAYS=90
S3_IA_TRANSITION_DAYS=30

# ============================================================
# SECURITY
# ============================================================
ENABLE_MFA=true
PASSWORD_MIN_LENGTH=8
TOKEN_EXPIRY_MINUTES=60

# ============================================================
# LOCAL DEVELOPMENT ONLY
# ============================================================
# For local testing without AWS credentials
# DO NOT use these in production Lambda functions
LOCAL_DEV_MODE=false
MOCK_SECRETS=false

